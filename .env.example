# Backend
PORT=3001
LOG_LEVEL=info
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?appName=autodev

# MongoDB (Docker Compose — local dev alternative)
MONGO_INITDB_ROOT_USERNAME=autodev
MONGO_INITDB_ROOT_PASSWORD=autodev_password
MONGO_DATABASE=autodev

# Frontend
VITE_API_URL=http://localhost:3001
