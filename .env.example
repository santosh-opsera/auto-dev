# Backend
PORT=3001
LOG_LEVEL=info
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?appName=autodev
ENCRYPTION_KEY=replace-with-32-byte-secret-in-production
FRONTEND_URL=http://localhost:3000

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/v1/auth/github/callback

# Atlassian OAuth
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:3001/api/v1/auth/atlassian/callback
ATLASSIAN_SITE_URL=https://your-site.atlassian.net
FORGE_BRIDGE_URL=

# MongoDB (Docker Compose — local dev alternative)
MONGO_INITDB_ROOT_USERNAME=autodev
MONGO_INITDB_ROOT_PASSWORD=autodev_password
MONGO_DATABASE=autodev

# Frontend
VITE_API_URL=http://localhost:3001

# SSRF protection (comma-separated hostnames for server-side fetches)
SSRF_ALLOWED_HOSTS=auth.atlassian.com,api.atlassian.com,github.com,api.github.com
