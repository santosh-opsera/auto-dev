# Backend
PORT=3002
LOG_LEVEL=info
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?appName=autodev
ENCRYPTION_KEY=replace-with-32-byte-secret-in-production
FRONTEND_URL=http://localhost:3001

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3002/api/v1/auth/github/callback

# Atlassian OAuth
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:3002/api/v1/auth/atlassian/callback
ATLASSIAN_SITE_URL=https://your-site.atlassian.net

# MongoDB (Docker Compose — local dev alternative)
MONGO_INITDB_ROOT_USERNAME=autodev
MONGO_INITDB_ROOT_PASSWORD=autodev_password
MONGO_DATABASE=autodev

# Frontend
# Local dev: backend on port 3002
VITE_API_URL=http://localhost:3002
# GitHub Pages (project site): app URL is https://santosh-opsera.github.io/auto-dev/
# Login: https://santosh-opsera.github.io/auto-dev/login — not /login at the root.
# Set repo variable VITE_API_URL to your deployed backend URL (e.g. https://api.example.com).
# Set backend FRONTEND_URL to https://santosh-opsera.github.io/auto-dev and update OAuth callbacks.

# SSRF protection (comma-separated hostnames for server-side fetches)
SSRF_ALLOWED_HOSTS=auth.atlassian.com,api.atlassian.com,github.com,api.github.com,api.openai.com,api.anthropic.com

# LLM adapter (WO-019)
# Keys are optional in local/dev when using the local provider stub.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PRIMARY_PROVIDER=local
LLM_FAILOVER_ORDER=openai,anthropic,local
LLM_PER_REQUEST_TOKEN_LIMIT=8000
LLM_DAILY_TOKEN_LIMIT=100000
LLM_CACHE_TTL_HOURS=24
LLM_LOCAL_MOCK_RESPONSE=
