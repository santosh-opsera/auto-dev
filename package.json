{
  "name": "autodev-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "SDLC developer automation — monorepo",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @autodev/backend\" \"npm run dev -w @autodev/frontend\"",
    "dev:backend": "npm run dev -w @autodev/backend",
    "dev:frontend": "npm run dev -w @autodev/frontend",
    "guard:build": "npm run guard:build -w @autodev/backend",
    "precommit:guard": "npm run precommit:guard -w @autodev/backend",
    "build": "npm run guard:build && npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test -w @autodev/e2e",
    "test:e2e:api": "npm run test:api -w @autodev/e2e",
    "test:e2e:ui": "npm run test:ui -w @autodev/e2e",
    "test:e2e:mocks": "npm run mocks -w @autodev/e2e",
    "validate:node22": "bash scripts/validate-node22.sh",
    "lint": "npm run lint --workspaces --if-present",
    "lint:boundaries": "npm run lint:boundaries -w @autodev/backend",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json}\"",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santosh-opsera/auto-dev.git"
  },
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^7.0.2",
    "husky": "^9.1.7",
    "prettier": "^3.9.4"
  }
}
