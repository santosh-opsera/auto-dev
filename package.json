{
  "name": "autodev-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "SDLC developer automation — monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @autodev/backend\" \"npm run dev -w @autodev/frontend\"",
    "dev:backend": "npm run dev -w @autodev/backend",
    "dev:frontend": "npm run dev -w @autodev/frontend",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santosh-opsera/auto-dev.git"
  },
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.9.4"
  }
}
